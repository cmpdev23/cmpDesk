# cmpDesk Environment Configuration
# ==================================
# Copy this file to .env and adjust values as needed.
# The .env file is gitignored and should never be committed.

# Environment: DEV or PROD
# - DEV: All logs enabled, DevTools available
# - PROD: Only warn/error logs, no DevTools
ENV=DEV

# Enable debug logging
# - true: Debug logs are printed (when LOG_LEVEL allows)
# - false: Debug logs are suppressed regardless of LOG_LEVEL
DEBUG_LOGS=true

# Automatically open DevTools on app start (DEV only)
# - true: DevTools opens automatically
# - false: DevTools stays closed (can still open manually with Ctrl+Shift+I)
SHOW_DEVTOOLS=false

# Log level threshold
# - debug: All logs (debug, info, warn, error)
# - info: info, warn, error only
# - warn: warn, error only
# - error: error only
LOG_LEVEL=debug


GH_RELEASE_TOKEN=your_github_token_here
